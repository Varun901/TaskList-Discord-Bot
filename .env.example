# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Schedule ──────────────────────────────────────────────────────────────────
# 24-hour format. Default: 08:00
DAILY_POST_HOUR=8
DAILY_POST_MINUTE=0

# Timezone for schedule and display.  See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Toronto

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_PATH=taskbot.db
